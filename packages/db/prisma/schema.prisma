generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  username        String           @unique @map("username")
  displayName     String           @map("display_name")
  preferredLang   String           @map("preferred_lang")
  pictureUrl      String?          @map("picture_url")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  chatMemberships ChatMember[]
  sentMessages    Message[]
  messageReceipts MessageReceipt[]

  @@index([username])
  @@index([displayName])
  @@map("users")
}

model Chat {
  id        String       @id @default(uuid()) @map("id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")
  members   ChatMember[]
  messages  Message[]

  @@map("chats")
}

model ChatMember {
  chatId    String   @map("chat_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  chat      Chat     @relation(fields: [chatId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([chatId, userId])
  @@map("chat_members")
}

model Message {
  id        String           @id @default(uuid()) @map("id") @db.Uuid
  chatId    String           @map("chat_id") @db.Uuid
  senderId  String           @map("sender_id") @db.Uuid
  contentId String           @unique @map("content_id") @db.Uuid
  isDeleted Boolean          @default(false) @map("is_deleted")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  chat      Chat             @relation(fields: [chatId], references: [id])
  content   MessageContent   @relation(fields: [contentId], references: [id])
  sender    User             @relation(fields: [senderId], references: [id])
  receipts  MessageReceipt[]

  @@index([chatId, createdAt(sort: Desc)])
  @@map("messages")
}

model MessageContent {
  id           String               @id @default(uuid()) @map("id") @db.Uuid
  originalLang String               @map("original_lang")
  textCipher   Bytes                @map("text_cipher")
  textNonce    Bytes                @map("text_nonce")
  encScheme    String               @default("v1") @map("enc_scheme")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  translations MessageTranslation[]
  messages     Message?

  @@map("message_contents")
}

model MessageTranslation {
  contentId            String         @map("content_id") @db.Uuid
  targetLang           String         @map("target_lang")
  translatedTextCipher Bytes          @map("translated_text_cipher")
  translatedTextNonce  Bytes          @map("translated_text_nonce")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  content              MessageContent @relation(fields: [contentId], references: [id])

  @@id([contentId, targetLang])
  @@index([contentId])
  @@map("message_translations")
}

model MessageReceipt {
  messageId   String    @map("message_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  message     Message   @relation(fields: [messageId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
  @@index([messageId])
  @@index([userId, readAt])
  @@map("message_receipts")
}
